{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": ["bun-types"],
    "paths": {
      "@/*": ["./src/*"],
      "@convex/*": ["./convex/*"],
      "@oncobase/chat": ["../../packages/chat/src/index.ts"],
      "@oncobase/chat/*": ["../../packages/chat/src/*"],
      "@oncobase/diagnostics": [
        "../../packages/diagnostics/src/index.ts"
      ],
      "@oncobase/diagnostics/timeline": [
        "../../packages/diagnostics/src/timeline/index.ts"
      ],
      "@oncobase/diagnostics/studies": [
        "../../packages/diagnostics/src/studies/index.ts"
      ],
      "@oncobase/diagnostics/*": [
        "../../packages/diagnostics/src/*"
      ],
      "@oncobase/smart-table": ["../../packages/smart-table/src/index.ts"],
      "@oncobase/smart-table/examples": [
        "../../packages/smart-table/src/example-tables.ts"
      ],
      "@oncobase/smart-table/layout-adapter": [
        "../../packages/smart-table/src/layout-adapter.ts"
      ],
      "@oncobase/oncobase": ["../../packages/oncobase/src/index.ts"],
      "@oncobase/wiki-content": [
        "../../packages/wiki-content/src/index.ts"
      ],
      "@oncobase/wiki-comments": [
        "../../packages/wiki-comments/src/index.tsx"
      ],
      "@oncobase/wiki-comments/*": [
        "../../packages/wiki-comments/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
