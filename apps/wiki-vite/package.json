{
  "name": "@diana-tnbc/wiki-vite",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "bun --cwd ../../packages/smart-table build && tsc --noEmit && vite build && bun scripts/build-vercel-functions.ts",
    "check:bundle": "bun scripts/check-bundle-budget.ts",
    "verify:standalone": "bun scripts/verify-standalone.ts",
    "start:server": "bun server/standalone.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test src server",
    "test:e2e": "playwright test",
    "test:e2e:endform": "endform test",
    "test:e2e:preview": "playwright test --config playwright.preview.config.ts"
  },
  "dependencies": {
    "@diana-tnbc/wiki-content": "workspace:*",
    "@diana-tnbc/wiki-markdown": "workspace:*",
    "@diana-tnbc/wiki-shell": "workspace:*",
    "@diana-tnbc/chat": "workspace:*",
    "@diana-tnbc/smart-table": "workspace:*",
    "@livestore/adapter-web": "0.3.1",
    "@livestore/livestore": "0.3.1",
    "@livestore/peer-deps": "0.3.1",
    "@livestore/react": "0.3.1",
    "@livestore/wa-sqlite": "1.0.5-dev.2",
    "ai": "^6.0.168",
    "archiver": "^7.0.1",
    "convex": "^1.34.1",
    "lucide-react": "^1.11.0",
    "openai": "^6.33.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/vite": "^4.1.17",
    "@livestore/devtools-vite": "0.3.1",
    "@playwright/test": "^1.59.1",
    "endform": "^0.62.0",
    "@types/archiver": "^7.0.0",
    "@vitejs/plugin-react": "6.0.1",
    "jszip": "^3.10.1",
    "bun-types": "^1.3.12",
    "typescript": "^5",
    "vite": "8.0.11"
  }
}
