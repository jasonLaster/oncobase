# Convex powers the Vite backend and the chat client.
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
CONVEX_URL=https://your-convex-deployment.convex.cloud
VITE_CONVEX_URL=https://your-convex-deployment.convex.cloud
VITE_NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud

# Required for unknown hosts such as a fresh vercel.app preview until the host is
# present in Convex site-domain records.
WIKI_SITE_SLUG=diana

# Required for live AI search and chat.
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=

# Optional. When omitted, the Vite dev server serves /api/wiki/*,
# /api/file, and /api/page-copy directly from Convex.
# VITE_WIKI_API_ORIGIN=http://localhost:3000

# Optional. Used for links that intentionally hand off to another app origin.
VITE_WIKI_APP_ORIGIN=http://localhost:3000

# Epic/UCSF SMART on FHIR lab-result ingestion.
# Generate a key with: openssl rand -base64 32
EPIC_FHIR_TOKEN_ENCRYPTION_KEY=
EPIC_FHIR_CLIENT_ID=
EPIC_FHIR_CLIENT_SECRET=
EPIC_FHIR_REDIRECT_URI=http://localhost:60001/api/integrations/epic/callback
EPIC_FHIR_BASE_URL=https://unified-api.ucsf.edu/clinical/apex/api/FHIR/R4
EPIC_FHIR_PROVIDER_KEY=ucsf
EPIC_FHIR_PROVIDER_NAME="UCSF Health Epic"
EPIC_FHIR_SCOPES="launch/patient openid fhirUser offline_access patient/Patient.read patient/Observation.read patient/DiagnosticReport.read patient/DocumentReference.read patient/Binary.read"
EPIC_FHIR_INITIAL_LOOKBACK_DAYS=180

# Optional manual/cron sync secret. Vercel Cron also sends CRON_SECRET when set.
EPIC_FHIR_SYNC_SECRET=
CRON_SECRET=
