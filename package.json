{
  "name": "diana-breast-cancer",
  "private": true,
  "workspaces": ["web", "apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev:app",
    "dev:local-convex": "turbo run dev:app dev:convex",
    "dev:wiki-vite": "bun --cwd apps/wiki-vite dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:unit": "turbo run test:unit",
    "test:e2e:wiki-vite": "bun --cwd apps/wiki-vite test:e2e"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "bun@1.3.12",
  "dependencies": {
    "@vercel/blob": "^2.3.3",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  }
}
