{
  "name": "@oncobase/wiki-content",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Shared wiki content contracts, tree helpers, and browser API client utilities.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./chat-tools": {
      "types": "./src/chat-tools.ts",
      "import": "./src/chat-tools.ts",
      "default": "./src/chat-tools.ts"
    },
    "./chat-route": {
      "types": "./src/chat-route.ts",
      "import": "./src/chat-route.ts",
      "default": "./src/chat-route.ts"
    },
    "./pii": {
      "types": "./src/pii.ts",
      "import": "./src/pii.ts",
      "default": "./src/pii.ts"
    },
    "./embeddings": {
      "types": "./src/embeddings.ts",
      "import": "./src/embeddings.ts",
      "default": "./src/embeddings.ts"
    },
    "./convex-url": {
      "types": "./src/convex-url.ts",
      "import": "./src/convex-url.ts",
      "default": "./src/convex-url.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test src/*.test.ts"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "^5"
  }
}
