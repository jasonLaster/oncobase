{
  "name": "@oncobase/diagnostics",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Shared diagnostics timeline and diagnostic study utilities.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./timeline": {
      "types": "./src/timeline/index.ts",
      "import": "./src/timeline/index.ts",
      "default": "./src/timeline/index.ts"
    },
    "./timeline/data": {
      "types": "./src/timeline/data.ts",
      "import": "./src/timeline/data.ts",
      "default": "./src/timeline/data.ts"
    },
    "./studies": {
      "types": "./src/studies/index.ts",
      "import": "./src/studies/index.ts",
      "default": "./src/studies/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test src/**/*.test.ts"
  },
  "dependencies": {
    "lucide-react": "^1.11.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.12",
    "typescript": "^5"
  }
}
