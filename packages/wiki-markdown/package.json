{
  "name": "@diana-tnbc/wiki-markdown",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Client-safe React markdown renderer for Diana wiki pages.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./src/index.tsx",
      "default": "./src/index.tsx"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./citations": {
      "types": "./src/citations.ts",
      "import": "./src/citations.ts",
      "default": "./src/citations.ts"
    },
    "./frame": {
      "types": "./src/frame.tsx",
      "import": "./src/frame.tsx",
      "default": "./src/frame.tsx"
    },
    "./math": {
      "types": "./src/math.ts",
      "import": "./src/math.ts",
      "default": "./src/math.ts"
    },
    "./paths": {
      "types": "./src/paths.ts",
      "import": "./src/paths.ts",
      "default": "./src/paths.ts"
    },
    "./mermaid": {
      "types": "./src/mermaid.tsx",
      "import": "./src/mermaid.tsx",
      "default": "./src/mermaid.tsx"
    },
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test src/*.test.ts"
  },
  "dependencies": {
    "@diana-tnbc/smart-table": "workspace:*",
    "beautiful-mermaid": "^1.1.3",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.12",
    "typescript": "^5"
  }
}
