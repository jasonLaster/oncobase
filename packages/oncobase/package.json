{
  "name": "@oncobase/oncobase",
  "version": "0.1.1",
  "private": false,
  "description": "Official Oncobase CLI for syncing, checking, and publishing Obsidian vaults.",
  "keywords": [
    "obsidian",
    "oncobase",
    "publisher",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonLaster/oncobase.git",
    "directory": "packages/oncobase"
  },
  "bugs": {
    "url": "https://github.com/jasonLaster/oncobase/issues"
  },
  "homepage": "https://github.com/jasonLaster/oncobase/tree/main/packages/oncobase",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "oncobase": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts src/main.ts src/init.ts src/check.ts src/publish.ts src/sync-command.ts src/skills-command.ts src/assets-backfill-hashes.ts --format esm --dts --platform node --target node20 --out-dir dist --clean",
    "pack:dry-run": "bun run build && bun pm pack --dry-run",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test src/*.test.ts"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.3",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.12",
    "tsup": "^8.5.0",
    "typescript": "^5"
  }
}
